# Copy to .env.local and fill in. .env.local is gitignored.
#
# Clerk: create an application at https://dashboard.clerk.com and grab keys from API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# GitHub fine-grained token with Contents: Read & Write on this repo.
# https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=jbehrens1/metrowest-events

# First sign-in for this email auto-promotes to 'owner' role.
# Owner can then assign admin/owner to other users via /admin.
OWNER_EMAIL=you@example.com

# Newsletter sending (Resend).
# 1) Sign up at https://resend.com (free tier covers 3k emails/month)
# 2) Verify your domain in Dashboard → Domains
# 3) Create an API key in Dashboard → API Keys
RESEND_API_KEY=re_...
# A from address on the verified domain (e.g. newsletter@goingson.co)
RESEND_FROM=newsletter@goingson.co

# Optional: signing secret for the Resend webhook (Dashboard → Webhooks).
# If unset, webhook events are still accepted (no signature check). Recommended
# for production.
RESEND_WEBHOOK_SECRET=whsec_...

# Random hex string used to sign one-click unsubscribe URLs. Generate with:
#   openssl rand -hex 32
UNSUBSCRIBE_SECRET=

# Optional: shared secret Vercel sends with cron requests. Generate with:
#   openssl rand -hex 32
# If unset, the cron endpoint accepts unauthenticated requests (NOT recommended).
CRON_SECRET=

# Public canonical URL of the deployed app (for absolute links in emails).
# Vercel auto-sets VERCEL_URL but it changes per deploy; use a stable URL.
NEXT_PUBLIC_APP_URL=https://www.goingson.co
