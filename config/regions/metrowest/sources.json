    {
      "id": "jcc-greater-boston",
      "name": "JCC Greater Boston",
      "enabled": true,
      "adapter": "wordpress-tribe-list",
      "url": "https://www.bostonjcc.org/",
      "category": "Venue",
      "town": "Newton",
      "notes": "WordPress + The Events Calendar (Tribe) plugin. REST API exposes only ~7 featured events, but /calendar/list/ shows the full calendar in JSON-LD with pagination. wordpress-tribe-list adapter scrapes those pages. titleRules catch the recurring Karishim youth-swim and Pre-Swim entries as family; defaultEventType=\"community\" covers the JCC's mixed adult programming.",
      "defaultEventType": "community",
      "titleRules": [
        {
          "pattern": "^karishim\\b|pre-?swim|swim lessons?",
          "type": "family"
        },
        {
